# ============================================================
#  Variables d'environnement — connexions vers les conteneurs Docker
#  Copie ce fichier en `.env` (non versionné) :  cp .env.example .env
#  Les valeurs ci-dessous correspondent EXACTEMENT à ton docker-compose.yml
# ============================================================

# --- PostgreSQL (service "postgres" -> port host 5433) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=dataops
POSTGRES_PASSWORD=dataops
POSTGRES_DB=oltp

# --- MinIO (service "minio" -> API sur 9000) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=raw

# --- DuckDB (fichier local, Data Warehouse analytique) ---
DUCKDB_PATH=warehouse.duckdb
